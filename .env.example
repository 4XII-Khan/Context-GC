# Context GC 大模型配置（摘要与合并摘要用）
# 复制为 .env 并填入实际值

# API 基址（OpenRouter 兼容）
CONTEXT_GC_BASE_URL=https://openrouter.ai/api/v1

# API Key（禁止提交到版本库）
CONTEXT_GC_API_KEY=your_api_key_here

# 模型名
CONTEXT_GC_MODEL=Qwen3.5-35B-A3B

# 可选：非 OpenRouter 地址但使用 Qwen「思考」模式时，若 L0/摘要出现空 content，可设为 1
# （OpenRouter 基址会自动附带关闭 thinking 的请求体，一般无需设置）
# CONTEXT_GC_DISABLE_THINKING=1

# ── 蒸馏（flush_distillation）──
# 会话原始消息条数低于此值时，内置默认路径跳过蒸馏（默认 4）
# CONTEXT_GC_FLUSH_MIN_MESSAGES=4
# 为 1/true 时，on_session_end 返回的 distillation 保留 trace 列表（默认不保留以减小体积）
# CONTEXT_GC_FLUSH_INCLUDE_TRACE=0
# default_call_llm_with_tools 单次 max_tokens（工具参数可能很长，默认 8192）
# CONTEXT_GC_FLUSH_TOOL_MAX_TOKENS=8192

# ── ASME E2E 测试 ──
# CONTEXT_GC_ASME_E2E_SKIP_MERGED=1
